rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: poets
    // Fields: name (string), bio (string), era (string), imageUrl (string), etc.
    //
    // Collection: poems
    // Fields: title (string), content (string), poetId (string), poetName (string), themes (list), mood (string), etc.
    //
    // Collection: users
    // Fields: email (string), role (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mderrickm00@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPoet(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.bio is string && data.bio.size() < 10000 &&
             data.era is string && data.era.size() < 100;
    }

    function isValidPoem(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.content is string && data.content.size() < 50000 &&
             data.poetId is string &&
             data.poetName is string;
    }

    function isValidUser(data) {
      return data.email is string &&
             data.role in ['admin', 'viewer'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Poets: Publicly readable, Admin writable
    match /poets/{poetId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidPoet(request.resource.data);
    }

    // Poems: Publicly readable, Admin writable
    match /poems/{poemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidPoem(request.resource.data);
    }

    // Users: Admin only
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
